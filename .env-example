# ── OAuth2 App Credentials ────────────────────────────────────────────────────
# Register a server-to-server OAuth2 app at https://operated.ochno.com
# Grant type: client_credentials
# Required scopes: sub email accounts:read accounts:write hubs:read hubs:write
# No redirect URI needed for server-to-server integration.

CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# The base URL of the Ochno Operated platform
OCHNO_BASE_URL=https://operated.ochno.com

# ── Webhooks (optional) ───────────────────────────────────────────────────────
# If set, a subscription will be created on startup and events streamed to the
# UI via socket.io. Use ngrok or similar to expose your local server.
# Example: https://abc123.ngrok.io  (no trailing slash)
# Leave empty to disable webhook functionality.
WEBHOOK_BASE_URL=